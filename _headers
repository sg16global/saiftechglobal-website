/*
  Cloudflare Pages headers (this folder = public web root).
  Cache HTML briefly at edge; long-cache fonts/assets.
  Link preloads help when Early Hints is enabled on the zone.
*/
/
  Cache-Control: public, max-age=300, s-maxage=3600
  Link: </assets/logo.webp>; rel=preload; as=image; type=image/webp, </css/site.css?v=3>; rel=preload; as=style
/index.html
  Cache-Control: public, max-age=300, s-maxage=3600
  Link: </assets/logo.webp>; rel=preload; as=image; type=image/webp, </css/site.css?v=3>; rel=preload; as=style
/privacy.html
  Cache-Control: public, max-age=300, s-maxage=3600
  Link: </css/site.css?v=3>; rel=preload; as=style
/sitemap.xml
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=86400
/robots.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=86400
/assets/*
  Cache-Control: public, max-age=604800, immutable
/css/*
  Cache-Control: public, max-age=86400
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
